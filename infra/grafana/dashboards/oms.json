{
  "title": "OMS Overview",
  "uid": "oms-overview",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Orders Received (total)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"expr": "sum(oms_orders_received_total)", "legendFormat": "Orders"}
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Orders Rejected (total)",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"expr": "sum(oms_orders_rejected_total)", "legendFormat": "Rejected"}
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Fills (total)",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"expr": "sum(oms_fills_total)", "legendFormat": "Fills"}
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Order Throughput (per second)",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "rate(oms_orders_received_total[1m])", "legendFormat": "Orders/s"}
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Order Processing Latency (p99)",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.99, rate(oms_order_latency_seconds_bucket[1m]))", "legendFormat": "p99 latency"}
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Fill Rate by Symbol",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
      "targets": [
        {"expr": "rate(oms_fills_total[1m])", "legendFormat": "{{symbol}} {{side}}"}
      ]
    }
  ]
}
