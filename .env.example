# Postgres
POSTGRES_DB=oms
POSTGRES_USER=oms
DATABASE_URL=postgresql://oms:******@postgres:5432/oms

# Kafka
KAFKA_BOOTSTRAP=kafka:9092

# Redis
REDIS_URL=redis://redis:6379/0

# FIX
FIX_CONFIG=/app/config/fix44.cfg
FIX_MD_CONFIG=/app/config/fix44_md.cfg

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
METRICS_PORT=8000
PRICE_COLLAR_PCT=0.10

# Grafana
GF_SECURITY_ADMIN_USER=admin
